# Gmail account used to SEND booking/contact emails.
# This does NOT have to be apexpetclinic74@gmail.com — it can be any Gmail
# account you control. All booking emails are sent TO apexpetclinic74@gmail.com
# regardless of which account is used here.
EMAIL_USER=your-sending-account@gmail.com

# A Gmail "App Password" — NOT your normal Gmail password.
# Generate one at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account)
EMAIL_PASS=xxxx xxxx xxxx xxxx
